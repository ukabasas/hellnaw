{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Nova3D (prod)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "args": [
        "--web-port=5555",
        "--web-hostname=127.0.0.1"
      ]
    },
    {
      "name": "Nova3D (dev — local backend)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "args": [
        "--web-port=5555",
        "--web-hostname=127.0.0.1",
        "--dart-define=AUTH_BASE_URL=http://127.0.0.1:8009",
        "--dart-define=CAD_BASE_URL=http://127.0.0.1:8009"
      ]
    }
  ]
}
